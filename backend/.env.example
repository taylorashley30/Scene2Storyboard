# Optional: Gemini API key for LLM caption enhancement (fixes transcript errors, cleaner storyboard captions).
# Leave unset to use rule-based captions only (no API cost).
# Get a free key from https://aistudio.google.com
# GEMINI_API_KEY=your_gemini_key_here

# Optional: Gemini model (default: gemini-2.0-flash). Override if needed for your project.
# GEMINI_MODEL=gemini-2.5-flash

# Optional: Gemini batching config (for videos with many scenes).
# GEMINI_MAX_SCENES_PER_REQUEST=30  # Scenes per API call (default: 30). Increase for paid tier.
# GEMINI_HARD_SCENE_CAP=200  # Max total scenes before skipping Gemini (default: 200). Increase for paid tier.
# GEMINI_BATCH_DELAY=2.0  # Seconds between batches (default: 2.0). Increase if you hit rate limits.

# Whisper model: base = fast; small/medium = balance; large-v2 = best quality, slow on CPU.
# S2S_WHISPER_MODEL_SIZE=base

# Scene detection tuning (to reduce repetition from short visual cuts):
# S2S_MIN_SCENE_DURATION=1.5  # Minimum scene duration in seconds (default: 1.5). Scenes shorter than this are merged with the previous scene.
# S2S_SCENE_THRESHOLD=30.0    # ContentDetector threshold (default: 30.0). Higher = less sensitive (fewer cuts detected).
